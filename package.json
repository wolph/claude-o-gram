{
  "name": "claude-o-gram",
  "version": "1.0.0",
  "description": "Claude-o-Gram: A Telegram bot that mirrors Claude Code sessions to forum topics",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install",
    "secrets:scan": "bash scripts/gitleaks.sh git --no-banner --redact=100 --log-opts='--all --full-history --reflog' .",
    "secrets:scan:staged": "bash scripts/gitleaks.sh git --no-banner --redact=100 --staged ."
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "BSD-3-Clause",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/parse-mode": "^2.2.1",
    "@grammyjs/transformer-throttler": "^1.2.1",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.5",
    "grammy": "^1.40.1",
    "lru-cache": "^11.2.6",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "@evilmartians/lefthook": "^1.12.4"
  }
}
