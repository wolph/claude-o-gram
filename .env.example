# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Required: Telegram group chat ID (negative number for supergroups, e.g. -1001234567890)
TELEGRAM_CHAT_ID=your-group-chat-id-here

# Optional: Port for the hook HTTP server (default: 3456)
HOOK_SERVER_PORT=3456

# Optional: Host for the hook HTTP server (default: 127.0.0.1)
HOOK_SERVER_HOST=127.0.0.1

# Optional: Directory for persistent data like session maps (default: ./data)
DATA_DIR=./data
